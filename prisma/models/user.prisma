model User {
  id           Int      @id @default(autoincrement())
  email        String   
  passwordHash String

  firstName    String
  lastName     String

  role         Role     @default(USER)

  status Boolean @default(true)

  createdAt    DateTime @default(now())
  updatedAt    DateTime? @updatedAt

  @@unique([email], where: { status: true })
}